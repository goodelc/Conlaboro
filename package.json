{"name": "conlaboro-all", "private": true, "version": "1.0.0", "scripts": {"test:frontend": "cd frontend && npx vitest run", "test:frontend:watch": "cd frontend && npx vitest", "test:backend": "cd backend && mvn test -Dtest=\"**/*Test\" --quiet 2>&1 | tail -30", "test:e2e": "npx playwright test", "test:e2e:ui": "npx playwright test --ui", "test:e2e:headed": "npx playwright test --headed", "install:all": "npm install && cd frontend && npm install && cd .. && npx playwright install chromium"}, "devDependencies": {"@playwright/test": "^1.48.2"}}